# ── Blockchain RPC (get free key at alchemy.com → create Polygon Mainnet app)
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# ── The Graph (get free key at thegraph.com/studio → API Keys)
# Polymarket subgraph ID on Polygon: 81Dm16JjuFSrqz813HysXoUPvzTwE7fsfPk7XtzQ3eLR
SUBGRAPH_URL=https://gateway.thegraph.com/api/YOUR_KEY_HERE/subgraphs/id/81Dm16JjuFSrqz813HysXoUPvzTwE7fsfPk7XtzQ3eLR

# ── Postgres (run: docker run --name polydb -e POSTGRES_PASSWORD=poly123 -e POSTGRES_DB=polymarket -p 5432:5432 -d postgres:16)
DATABASE_URL=postgresql+asyncpg://postgres:poly123@localhost/polymarket

# RabbitMQ local credentials
RABBITMQ_DEFAULT_USER=poly_app
RABBITMQ_DEFAULT_PASS=poly_local_password
RABBITMQ_ERLANG_COOKIE=poly_local_erlang_cookie

# ── Tuning
POLL_INTERVAL_SECONDS=30
INSIDER_THRESHOLD=0.65
